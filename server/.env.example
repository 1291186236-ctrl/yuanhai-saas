# 数据库
DATABASE_URL=postgresql://user:pass@localhost:5432/yuanhai

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Lemon Squeezy
LS_API_KEY=your-lemon-squeezy-api-key
LS_STORE_ID=your-store-id
LS_WEBHOOK_SECRET=your-webhook-signing-secret
LS_PRODUCT_PRO_MONTHLY_VARIANT_ID=variant_id_pro_monthly
LS_PRODUCT_PRO_YEARLY_VARIANT_ID=variant_id_pro_yearly
LS_PRODUCT_ENT_MONTHLY_VARIANT_ID=variant_id_ent_monthly
LS_PRODUCT_ENT_YEARLY_VARIANT_ID=variant_id_ent_yearly

# 邮件（Resend）
RESEND_API_KEY=re_xxx
MAIL_FROM=noreply@yourdomain.com

# 前端
WEB_ORIGIN=https://app.yourdomain.com
EXTENSION_ID=your-extension-id

# 环境
NODE_ENV=development
PORT=3000
