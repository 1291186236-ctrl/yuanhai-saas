{
  "buildCommand": "cd web && npm install && npm run build && cd ../server && npm install",
  "outputDirectory": "web/dist",
  "installCommand": "npm install --prefix web && npm install --prefix server",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/[[path]].js": {
      "runtime": "nodejs20.x"
    }
  }
}
