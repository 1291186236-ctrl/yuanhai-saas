{
  "manifest_version": 3,
  "name": "商品自动化助手",
  "version": "2.0.0",
  "description": "自动化商品分析和AI生图工作流 - 商业版",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "downloads",
    "tabs",
    "windows",
    "sidePanel",
    "clipboardRead",
    "clipboardWrite",
    "debugger",
    "identity"
  ],
  "host_permissions": [
    "*://*/*",
    "https://accounts.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "action": {
    "default_title": "商品自动化助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content/doubao-interceptor.js", "content/generic-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*/*"],
      "js": [
        "content/utils.js",
        "content/picker.js",
        "content/validator.js",
        "content/player.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "settings/settings.html",
  "web_accessible_resources": [
    {
      "resources": ["auth/login.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
